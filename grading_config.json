{
  "environment": {
    "name": "email-triage-env",
    "version": "1.0",
    "description": "Email triage RL environment with task grading"
  },
  "tasks": [
    {
      "id": "easy_spam",
      "name": "easy_spam",
      "display_name": "Easy Spam Classification",
      "description": "Simple spam email classification task",
      "grading_enabled": true,
      "grading_function": "env.graders.grade_easy_spam",
      "score_bounds": [0.005, 0.994]
    },
    {
      "id": "medium_meeting",
      "name": "medium_meeting",
      "display_name": "Medium Meeting Classification",
      "description": "Medium difficulty meeting email classification task",
      "grading_enabled": true,
      "grading_function": "env.graders.grade_medium_meeting",
      "score_bounds": [0.005, 0.994]
    },
    {
      "id": "hard_multi",
      "name": "hard_multi",
      "display_name": "Hard Multi-Intent Classification",
      "description": "Hard difficulty multi-intent email classification task",
      "grading_enabled": true,
      "grading_function": "env.graders.grade_hard_multi",
      "score_bounds": [0.005, 0.994]
    },
    {
      "id": "support_request",
      "name": "support_request",
      "display_name": "Support Request Classification",
      "description": "Support request email classification task",
      "grading_enabled": true,
      "grading_function": "env.graders.grade_support_request",
      "score_bounds": [0.005, 0.994]
    }
  ],
  "validation": {
    "min_tasks_with_graders": 3,
    "total_tasks_with_graders": 4,
    "score_range_valid": true,
    "score_min": 0.005,
    "score_max": 0.994
  }
}
